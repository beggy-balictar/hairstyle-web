# Copy to .env.local (recommended) or .env. Restart `npm run dev` after changes.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/stylehair"
# Optional (recommended for hosted Postgres): direct non-pooler URL for Prisma CLI
# operations (migrate/db push), while DATABASE_URL can stay pooled for runtime.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/stylehair?sslmode=require"

AUTH_SECRET="use-a-random-string-at-least-32-characters-long"

# Optional: AI hairstyle try-on (Gemini image model).
# Paste the KEY only (AIza…), not the https://aistudio.google.com/... URL. See https://aistudio.google.com/apikey
# If unset, POST /api/generate/hairstyle-preview returns 503.
# GEMINI_HAIRSTYLE_MODEL="gemini-2.5-flash-image"
# GEMINI_API_KEY=

# AI preview quotas (per signed-in customer, UTC calendar day). 0 = unlimited / no cooldown.
# Defaults if unset: 10 previews per day, 60s minimum between previews.
# HAIRSTYLE_PREVIEW_MAX_PER_USER_PER_DAY="10"
# HAIRSTYLE_PREVIEW_MIN_SECONDS_BETWEEN="60"

# Admin: do not put passwords here. After `npm run db:push`, open /first-admin-setup once
# to create the first admin with your chosen name@stylehair.com and password.
